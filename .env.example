# Kleos — environment configuration
# Copy to .env and fill in the required values.
# Required values are marked with (required).

# ---------------------------------------------------------------------------
# Core server
# ---------------------------------------------------------------------------

# Bearer token for the API.
# Leave empty on first run — generate after bootstrap:
#   curl -s -X POST http://localhost:4200/bootstrap \
#        -H "Content-Type: application/json" \
#        -d '{"secret":"<your-bootstrap-secret>","label":"admin"}' | jq .key
KLEOS_API_KEY=

# (required) One-time secret used to bootstrap the first API key.
# Set before first start, then keep it safe — it grants full admin access.
KLEOS_BOOTSTRAP_SECRET=

# Tenant mode: single (default) or sharded
KLEOS_TENANT_MODE=single

# Host binding and port for the server (default: 127.0.0.1:4200)
KLEOS_BIND=127.0.0.1
KLEOS_PORT=4200

# Persistent data directory on the host (default: ./data/kleos)
KLEOS_DATA_DIR=./data/kleos

# ---------------------------------------------------------------------------
# Embedding
# ---------------------------------------------------------------------------

# Provider: ollama (default) | openai | tei
KLEOS_EMBEDDING_PROVIDER=ollama
KLEOS_EMBEDDING_MODEL=nomic-embed-text

# Ollama URL reachable from inside the container
KLEOS_OLLAMA_URL=http://host.docker.internal:11434

# OpenAI key — only needed when KLEOS_EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Sidecar
# ---------------------------------------------------------------------------

# (required if using sidecar) Shared secret between sidecar and server
KLEOS_SIDECAR_TOKEN=

KLEOS_SIDECAR_BIND=127.0.0.1
KLEOS_SIDECAR_PORT=7711

# ---------------------------------------------------------------------------
# GUI  (only used with: docker compose -f compose.yaml -f docker/gui.yml up)
# ---------------------------------------------------------------------------

# (required for GUI) Setting this enables the web interface.
KLEOS_GUI_PASSWORD=

KLEOS_GUI_BIND=127.0.0.1
KLEOS_GUI_PORT=4200

# Optional: host path to a music directory served by the player
# KLEOS_MUSIC_DIR=/path/to/music

# ---------------------------------------------------------------------------
# Credential daemon + Phylax  (only used with --profile full)
# ---------------------------------------------------------------------------

# Auth mode: password | yubikey
CREDD_AUTH_MODE=password
CREDD_MASTER_PASSWORD=
