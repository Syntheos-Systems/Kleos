#!/usr/bin/env bash
# Pre-push gate: run the fast CI checks (rustfmt + clippy + cargo-deny + MSRV)
# before a push completes, so trivial failures come back in a couple of minutes
# locally instead of after a ~25-minute CI cycle. The slow test suite is left to
# CI; run it locally on demand with `scripts/preflight.sh --full`.
#
# Install: scripts/install-git-hooks.sh   (points core.hooksPath at .githooks)
# Bypass:  PREFLIGHT_SKIP=1 git push      (use sparingly; record why)

set -euo pipefail

# git streams the refs being pushed on stdin; drain it so the hook never blocks.
cat >/dev/null || true

if [[ "${PREFLIGHT_SKIP:-0}" == "1" ]]; then
    echo "pre-push: PREFLIGHT_SKIP=1 set -- skipping local CI gate."
    exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"

# Optional machine-local gate, run before the repo's own checks. Maintainers can
# point this at any additional policy check they want applied to outbound
# content; it is not part of the repo's required checks and is absent by default,
# so contributors are unaffected. A non-zero exit aborts the push.
LOCAL_GATE="${GIT_LOCAL_PREPUSH_GATE:-$HOME/.config/git/local-prepush-gate}"
if [[ -x "$LOCAL_GATE" ]]; then
    "$LOCAL_GATE" || exit 1
fi

if [[ ! -f "$ROOT/scripts/preflight.sh" ]]; then
    echo "pre-push: scripts/preflight.sh missing -- skipping." >&2
    exit 0
fi

# Invoke via `bash` rather than exec'ing the script directly: the repo lives on
# a filesystem with core.fileMode = false, so the script's executable bit is not
# reliable. bash reads it regardless, so the gate always runs.
echo "pre-push: running scripts/preflight.sh (fmt + clippy + deny). PREFLIGHT_SKIP=1 to bypass."
exec bash "$ROOT/scripts/preflight.sh"
