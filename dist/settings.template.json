{
  "env": {
    "KLEOS_URL": "http://172.30.0.201:4200",
    "EIDOLON_URL": "http://172.30.0.201:4200",
    "KLEOS_SIDECAR_URL": "http://127.0.0.1:4201"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "kleos-cli hook session-start",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "kleos-cli hook user-prompt",
            "timeout": 8
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "kleos-cli hook stop",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "kleos-sh --claude-hook --gate-only",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "agent-forge enforce --hook",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "kleos-cli hook post-bash",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
